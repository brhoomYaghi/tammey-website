# ── SQL Server connection ──────────────────────────────────
DB_SERVER=localhost          # your SQL Server hostname or IP
DB_PORT=1433
DB_DATABASE=TammeyDB        # your database name
DB_USER=sa                  # SQL Server login
DB_PASSWORD=YourPassword!   # SQL Server password
DB_ENCRYPT=false            # set true for Azure SQL
DB_TRUST_CERT=true          # set false in production with valid cert

# ── API settings ───────────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=http://localhost       # your website domain, e.g. https://tammey.org

# ── Admin secret (for protected write routes) ──────────────
ADMIN_SECRET=change-me-to-a-long-secret-key
